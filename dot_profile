#!/bin/bash
# shellcheck disable=SC1091

# Reset PATH to system defaults
PATH=$(getconf PATH)

# Paths to add (lower paths come first)
PATH_LIST="
/Applications/Obsidian.app/Contents/MacOS
/opt/homebrew/opt/openjdk/bin
/opt/homebrew/opt/findutils/libexec/gnubin
/usr/local/bin
/var/lib/snapd/snap/bin
$HOME/.lmstudio/bin
$HOME/.omlx/bin
$HOME/.rbenv/bin
$HOME/.npm-global/bin
$HOME/.cargo/bin
$HOME/.bun/bin
$HOME/.vite-plus/bin
$HOME/Library/pnpm
$HOME/.pyenv/shims
$HOME/.pyenv/bin
$HOME/.mint/bin
$HOME/.opencode/bin
$HOME/bin
$HOME/.bin
$HOME/.local/bin
$HOME/.local/bin/node
/usr/libexec
/Library/Apple/usr/bin
/System/Cryptexes/App/usr/bin
/sbin
/opt/local/bin
/opt/homebrew/sbin
/opt/homebrew/bin
"

# Use subshell to set PATH
PATH=$(echo "$PATH_LIST" | while read -r dir; do
    if [ -n "$dir" ] && [ -d "$dir" ]; then
        echo -n "$dir:"
    fi
done)$PATH

# Ensure critical system paths are included
for dir in /usr/local/sbin /usr/local/bin /usr/sbin /usr/bin /sbin /bin; do
    if [[ ":$PATH:" != *":$dir:"* ]]; then
        PATH="$PATH:$dir"
    fi
done

# Basic ls aliases
if command -v eza &>/dev/null; then
    alias ls='eza -bg'
    alias ll='eza -laFb'
    alias l='eza -1'
    alias la='eza -1a'
else
    alias ls='ls --color=auto'
    alias ll='ls -l'
    alias l='ls -lFh'
    alias la='ls -lAFh'
fi
